<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reserve Shop</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <!-- Custom Styles -->
  <style>
    body {
      background: #f0f2f5;
      min-height: 100vh;
    }
    /* Sidebar spacing */
    .main-content {
      margin-left: 280px;
      padding: 20px;
      min-height: 100vh;
    }
    /* No sidebar for login/register pages */
    .no-sidebar {
      margin-left: 0 !important;
    }
    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
      }
    }
    .auth-wrapper {
      min-height: 90vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card-shadow {
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
      border: none;
      border-radius: 16px;
    }
    .btn-primary {
      background: #4f46e5;
      border: none;
    }
    .btn-primary:hover {
      background: #4338ca;
    }
    /* Sidebar hover effect */
    .hover-bg:hover {
      background-color: rgba(255,255,255,0.1);
    }
    .hover-bg-danger:hover {
      background-color: rgba(220,53,69,0.2);
    }
    .sidebar .nav-link {
      transition: all 0.2s ease;
      border-radius: 6px;
      color: #e5e7eb !important;
    }

    .sidebar .nav-link:hover {
      background-color: rgba(255,255,255,0.1) !important;
    }

    .sidebar .nav-link.active,
    .sidebar .nav-link.bg-primary {
      background-color: #4f46e5 !important;
      color: #ffffff !important;
    }

    /* When collapsed, keep active link visible but cleaner */
    .sidebar.collapsed .nav-link.bg-primary {
      background-color: #4f46e5 !important;
      border-radius: 6px;
    }

    .sidebar.collapsed .nav-link:hover {
      background-color: rgba(255,255,255,0.1) !important;
    }
    @media (max-width: 991.98px) {
      .sidebar {
        display: none;
      }
    }
    @media (min-width: 992px) {
      .sidebar {
        display: flex !important;
      }
      .offcanvas {
        display: none !important;
      }
    }

        /* ─── SIDEBAR ─── */
    .sidebar {
      width: 280px;
      min-height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 1000;
      transition: width 0.3s ease;
      overflow: hidden;
      white-space: nowrap;
    }

    /* Collapsed state */
    .sidebar.collapsed {
      width: 70px !important;
    }

    .sidebar.collapsed #brandText {
      display: none;
    }

    .sidebar.collapsed .nav-link span {
      display: none;
    }

    .sidebar.collapsed .nav-link i {
      margin-right: 0 !important;
      font-size: 1.2rem;
    }

    /* 👇 FIX: Hide section labels and HR */
    .sidebar.collapsed .sidebar-section-label {
      display: none !important;
    }

    .sidebar.collapsed hr {
      display: none !important;
    }

    .sidebar.collapsed .sidebar-footer-text {
      display: none;
    }

    /* Main content adjustment */
    .main-content {
      margin-left: 280px;
      padding: 20px;
      min-height: 100vh;
      transition: margin-left 0.3s ease;
    }

    .sidebar.collapsed ~ .main-content {
      margin-left: 70px !important;
    }

    .no-sidebar {
      margin-left: 0 !important;
    }


  </style>
</head>
<body>

<!-- Sidebar Partial (Only show when logged in) -->
<% if (user && user.userId) { %>
  <%- include('sidebar') %>
<% } %>

<!-- Main Content Wrapper -->
<div class="main-content <% if (!user || !user.userId) { %>no-sidebar<% } %>">