<%- include('../partials/header') %>

<div class="row mt-4">
  <div class="col-12">
    <h2><i class="fas fa-clock text-primary me-2"></i>Attendance</h2>
    <hr>
  </div>
</div>


<!-- Flash Messages -->
<% if (message) { %>
  <div class="alert alert-info alert-dismissible fade show" role="alert">
    <%= message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- Staff Actions -->
<div class="row mb-4">
  <div class="col-md-6">
    <div class="card card-shadow">
      <div class="card-body text-center">
        <h5 class="mb-3">
          <i class="fas fa-user-circle text-primary me-2"></i><%= user.full_name || userEmail %>
        </h5>
        
        <% if (today && today.check_in && !today.check_out) { %>
          <div class="alert alert-success">
            <i class="fas fa-check-circle me-2"></i> You are currently <strong>clocked in</strong>
            <br><small>Since: <%= today.check_in %></small>
          </div>
          <form method="POST" action="/attendance/check-out">
            <button type="submit" class="btn btn-danger btn-lg w-100">
              <i class="fas fa-sign-out-alt me-2"></i>Clock Out
            </button>
          </form>
        <% } else if (today && today.check_in && today.check_out) { %>
          <div class="alert alert-secondary">
            <i class="fas fa-check-circle me-2"></i> You clocked out at <strong><%= today.check_out %></strong>
            <br><small>Hours worked: <%= today.hours_worked || 'N/A' %></small>
          </div>
          <button class="btn btn-secondary btn-lg w-100" disabled>
            <i class="fas fa-check me-2"></i>Done for Today
          </button>
        <% } else { %>
          <div class="alert alert-warning">
            <i class="fas fa-clock me-2"></i> You haven't clocked in today
          </div>
          <form method="POST" action="/attendance/check-in">
            <button type="submit" class="btn btn-success btn-lg w-100">
              <i class="fas fa-sign-in-alt me-2"></i>Clock In
            </button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Weekly Summary -->
  <div class="col-md-6">
    <div class="card card-shadow">
      <div class="card-body">
        <h5><i class="fas fa-chart-bar text-primary me-2"></i>Weekly Summary</h5>
        <div class="mt-3">
          <% if (history.length === 0) { %>
            <p class="text-muted">No attendance records yet.</p>
          <% } else { %>
            <ul class="list-group list-group-flush">
              <% history.forEach(day => { %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                  <span><%= new Date(day.date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %></span>
                  <span>
                    <% if (day.check_in) { %>
                      <span class="badge bg-success">✅ <%= day.check_in %></span>
                    <% } else { %>
                      <span class="badge bg-danger">❌ Absent</span>
                    <% } %>
                  </span>
                  <span>
                    <% if (day.hours_worked) { %>
                      <span class="badge bg-info"><%= day.hours_worked %> hrs</span>
                    <% } else if (day.check_in && !day.check_out) { %>
                      <span class="badge bg-warning">In progress</span>
                    <% } else { %>
                      <span class="badge bg-secondary">-</span>
                    <% } %>
                  </span>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Admin: Staff Currently Clocked In -->
<% if (isAdmin && clockedInStaff.length > 0) { %>
  <div class="row mt-3">
    <div class="col-12">
      <div class="card card-shadow">
        <div class="card-body">
          <h5><i class="fas fa-users text-primary me-2"></i>Staff Currently Clocked In</h5>
          <div class="table-responsive mt-3">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Clocked In</th>
                </tr>
              </thead>
              <tbody>
                <% clockedInStaff.forEach(staff => { %>
                  <tr>
                    <td><%= staff.full_name || 'N/A' %></td>
                    <td><%= staff.email %></td>
                    <td><span class="badge bg-success"><%= staff.check_in %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>