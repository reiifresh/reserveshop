<%- include('../partials/header') %>

<div class="row mt-4">
  <div class="col-12">
    <h2><i class="fas fa-coins text-success me-2"></i>Allocate Leave Credits</h2>
    <hr>
  </div>
</div>

<% if (message) { %>
  <div class="alert alert-info alert-dismissible fade show" role="alert">
    <%= message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="row">
  <div class="col-md-6 mx-auto">
    <div class="card card-shadow border-0">
      <div class="card-body p-4">
        <p class="text-muted small">Allocate or update leave credits for active staff members.</p>

        <form method="POST" action="/leave/allocate">
          <!-- Staff Dropdown -->
          <div class="mb-3">
            <label class="form-label">Staff Member <span class="text-danger">*</span></label>
            <select name="staff_id" class="form-select" required>
              <option value="">— Select Staff —</option>
              <% staff.forEach(s => { %>
                <option value="<%= s.id %>"><%= s.full_name || s.email %></option>
              <% }) %>
            </select>
          </div>

          <!-- Leave Type -->
          <div class="mb-3">
            <label class="form-label">Leave Type <span class="text-danger">*</span></label>
            <select name="leave_type" class="form-select" required>
              <option value="vacation">Vacation</option>
              <option value="sick">Sick</option>
              <option value="emergency">Emergency</option>
            </select>
          </div>

          <!-- Number of Days -->
          <div class="mb-3">
            <label class="form-label">Number of Days <span class="text-danger">*</span></label>
            <input type="number" name="days" class="form-control" placeholder="15" min="1" max="365" required>
          </div>

          <!-- Year -->
          <div class="mb-3">
            <label class="form-label">Year <span class="text-danger">*</span></label>
            <input type="number" name="year" class="form-control" value="<%= new Date().getFullYear() %>" min="2020" max="2030" required>
          </div>

          <button type="submit" class="btn btn-success w-100">
            <i class="fas fa-save me-2"></i>Allocate Credits
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>