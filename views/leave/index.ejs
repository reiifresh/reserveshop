<%- include('../partials/header') %>

<div class="row mt-4">
  <div class="col-12">
    <h2><i class="fas fa-umbrella-beach text-primary me-2"></i>My Leave</h2>
    <hr>
  </div>
</div>

<% if (message) { %>
  <div class="alert alert-info alert-dismissible fade show" role="alert">
    <%= message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="row g-4">

  <!-- Leave Balances -->
  <div class="col-md-4">
    <div class="card card-shadow border-0">
      <div class="card-body">
        <h5><i class="fas fa-coins text-warning me-2"></i>Leave Balances</h5>
        <div class="mt-3">
          <% ['vacation', 'sick', 'emergency'].forEach(type => { %>
            <% const balance = balances.find(b => b.leave_type === type); %>
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span><%= type.charAt(0).toUpperCase() + type.slice(1) %></span>
              <span>
                <strong><%= balance ? balance.remaining_days : '0' %></strong>
                <span class="text-muted small">/ <%= balance ? balance.total_days : '0' %></span>
              </span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <!-- Request Leave -->
  <div class="col-md-8">
    <div class="card card-shadow border-0">
      <div class="card-body">
        <h5><i class="fas fa-paper-plane text-success me-2"></i>Request Leave</h5>
        <form method="POST" action="/leave/request" class="mt-3">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">Leave Type</label>
              <select name="leave_type" class="form-select" required>
                <option value="vacation">Vacation</option>
                <option value="sick">Sick</option>
                <option value="emergency">Emergency</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">Start Date</label>
              <input type="date" name="start_date" class="form-control" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">End Date</label>
              <input type="date" name="end_date" class="form-control" required>
            </div>
            <div class="col-md-12">
              <label class="form-label">Reason (Optional)</label>
              <textarea name="reason" class="form-control" rows="2" placeholder="Any notes..."></textarea>
            </div>
            <div class="col-md-12">
              <button type="submit" class="btn btn-success">
                <i class="fas fa-paper-plane me-2"></i>Submit Request
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Leave History -->
  <div class="col-12">
    <div class="card card-shadow border-0">
      <div class="card-body">
        <h5><i class="fas fa-history text-primary me-2"></i>Leave History</h5>
        <% if (history.length === 0) { %>
          <p class="text-muted">No leave requests yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>Type</th>
                  <th>Dates</th>
                  <th>Days</th>
                  <th>Reason</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% history.forEach(req => { %>
                  <tr>
                    <td><%= req.leave_type %></td>
                    <td><%= new Date(req.start_date).toLocaleDateString() %> - <%= new Date(req.end_date).toLocaleDateString() %></td>
                    <td><%= req.days_requested %></td>
                    <td><%= req.reason || '—' %></td>
                    <td>
                      <span class="badge 
                        <%= req.status === 'approved' ? 'bg-success' : 
                            req.status === 'rejected' ? 'bg-danger' :
                            req.status === 'cancelled' ? 'bg-secondary' : 'bg-warning' %>">
                        <%= req.status %>
                      </span>
                    </td>
                    <td>
                      <% if (req.status === 'pending') { %>
                        <form method="POST" action="/leave/cancel/<%= req.id %>" style="display:inline;">
                          <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="fas fa-times"></i>
                          </button>
                        </form>
                      <% } else { %>
                        <span class="text-muted small">—</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>