<%- include('../partials/header') %>

<div class="row mt-4 mb-3 align-items-center">
  <div class="col-md-6">
    <h2><i class="fas fa-address-book text-primary me-2"></i>My Contacts</h2>
  </div>
  <div class="col-md-6">
    <div class="d-flex gap-2">
      <!-- Search Form -->
      <form method="GET" action="/contacts" class="flex-grow-1">
        <div class="input-group">
          <input type="text" name="search" class="form-control" placeholder="Search by name, email, or company..." value="<%= search || '' %>">
          <button class="btn btn-outline-primary" type="submit">
            <i class="fas fa-search"></i>
          </button>
        </div>
      </form>
      <!-- Add Contact Button -->
      <a href="/contacts/add" class="btn btn-primary flex-shrink-0">
        <i class="fas fa-plus me-2"></i>Add
      </a>
    </div>
  </div>
</div>

<!-- Show search results count -->
<% if (search) { %>
  <div class="alert alert-light border">
    <i class="fas fa-search me-2"></i>Showing results for "<strong><%= search %></strong>" 
    (<%= contacts.length %> found)
    <a href="/contacts" class="float-end text-decoration-none">Clear Search</a>
  </div>
<% } %>

<% if (contacts.length === 0) { %>
  <div class="alert alert-info">
    <i class="fas fa-info-circle me-2"></i>No contacts yet. Click "Add Contact" to get started!
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm bg-white rounded">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Company</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% contacts.forEach(contact => { %>
          <tr>
            <td><strong><%= contact.name %></strong></td>
            <td><%= contact.email || '-' %></td>
            <td><%= contact.phone || '-' %></td>
            <td><%= contact.company || '-' %></td>
            <td class="text-center">
              <a href="/contacts/edit/<%= contact.id %>" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-edit"></i>
              </a>
              <a href="/contacts/delete/<%= contact.id %>" class="btn btn-sm btn-outline-danger" 
                 onclick="return confirm('Are you sure you want to delete this contact?')">
                <i class="fas fa-trash"></i>
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>