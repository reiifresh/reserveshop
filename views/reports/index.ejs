<%- include('../partials/header') %>

<div class="row mt-4">
  <div class="col-12">
    <h2><i class="fas fa-file-export text-primary me-2"></i>Export Reports</h2>
    <hr>
    <p class="text-muted">Download data as CSV files for analysis, payroll, or compliance.</p>
  </div>
</div>

<% if (message) { %>
  <div class="alert alert-info"><%= message %></div>
<% } %>

<div class="row g-4">

  <!-- Attendance Report -->
  <div class="col-md-4">
    <div class="card card-shadow border-0 h-100">
      <div class="card-body text-center py-4">
        <i class="fas fa-clock fa-3x text-primary mb-3"></i>
        <h5>Attendance Report</h5>
        <p class="text-muted small">Export attendance records with dates, hours, and status.</p>
        <form method="GET" action="/reports/attendance" class="mt-3">
          <div class="row g-2">
            <div class="col-6">
              <input type="date" name="start_date" class="form-control form-control-sm" placeholder="Start">
            </div>
            <div class="col-6">
              <input type="date" name="end_date" class="form-control form-control-sm" placeholder="End">
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-sm w-100 mt-2">
            <i class="fas fa-download me-1"></i>Download CSV
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Leave Report -->
  <div class="col-md-4">
    <div class="card card-shadow border-0 h-100">
      <div class="card-body text-center py-4">
        <i class="fas fa-umbrella-beach fa-3x text-success mb-3"></i>
        <h5>Leave Report</h5>
        <p class="text-muted small">Export leave balances (total, used, remaining) for all staff.</p>
        <a href="/reports/leave" class="btn btn-success btn-sm w-100 mt-3">
          <i class="fas fa-download me-1"></i>Download CSV
        </a>
      </div>
    </div>
  </div>

  <!-- Activity Log Report -->
  <% if (user && user.role === 'admin') { %>
  <div class="col-md-4">
    <div class="card card-shadow border-0 h-100">
      <div class="card-body text-center py-4">
        <i class="fas fa-history fa-3x text-warning mb-3"></i>
        <h5>Activity Log Report</h5>
        <p class="text-muted small">Export recent activity logs for audit or compliance.</p>
        <form method="GET" action="/reports/activity" class="mt-3">
          <div class="mb-2">
            <select name="days" class="form-select form-select-sm">
              <option value="30">Last 30 days</option>
              <option value="60">Last 60 days</option>
              <option value="90">Last 90 days</option>
              <option value="365">Last year</option>
            </select>
          </div>
          <button type="submit" class="btn btn-warning btn-sm w-100">
            <i class="fas fa-download me-1"></i>Download CSV
          </button>
        </form>
      </div>
    </div>
  </div>
  <% } %>

</div>

<%- include('../partials/footer') %>