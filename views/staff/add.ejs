<%- include('../partials/header') %>

<div class="row mt-4">
  <div class="col-md-6 mx-auto">
    <div class="card card-shadow">
      <div class="card-body p-4">
        <h4 class="mb-3"><i class="fas fa-user-plus text-success me-2"></i>Add Staff</h4>
        <p class="text-muted small">Fill in the details below to create a new staff account.</p>
        
        <% if (error) { %>
          <div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i><%= error %></div>
        <% } %>
        
        <% if (success) { %>
          <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i><%- success %></div>
        <% } %>

        <form method="POST" action="/staff/add">
          <!-- Full Name -->
          <div class="mb-3">
            <label class="form-label">Full Name <span class="text-danger">*</span></label>
            <input type="text" name="fullName" class="form-control" placeholder="e.g., John Doe" required>
          </div>

          <!-- Email -->
          <div class="mb-3">
            <label class="form-label">Email <span class="text-danger">*</span></label>
            <input type="email" name="email" class="form-control" placeholder="employee@company.com" required>
          </div>

          <!-- Role Dropdown -->
          <div class="mb-3">
            <label class="form-label">Role <span class="text-danger">*</span></label>
            <select name="role" class="form-select" required>
              <option value="staff">Staff</option>
              <option value="hr_manager">HR Manager</option>
            </select>
            <small class="text-muted">
              <strong>Staff:</strong> Basic access (attendance, schedule, leave).<br>
              <strong>HR Manager:</strong> Can manage leave, attendance, and schedule requests.
            </small>
          </div>

          <!-- ─── PAY TYPE ─── -->
          <div class="mb-3">
            <label class="form-label">Pay Type <span class="text-danger">*</span></label>
            <select name="pay_type" class="form-select" id="payTypeSelect" required>
              <option value="hourly">Hourly</option>
              <option value="salary">Salary (Fixed Monthly)</option>
            </select>
            <small class="text-muted">
              <strong>Hourly:</strong> Paid based on hours worked.<br>
              <strong>Salary:</strong> Fixed monthly pay (for Admin/HR).
            </small>
          </div>

          <!-- Hourly Rate (visible by default) -->
          <div class="mb-3" id="hourlyRateField">
            <label class="form-label">Hourly Rate (₱)</label>
            <input type="number" name="hourly_rate" class="form-control" placeholder="500.00" step="0.01" min="0">
          </div>

          <!-- Monthly Salary (hidden by default) -->
          <div class="mb-3" id="monthlySalaryField" style="display:none;">
            <label class="form-label">Monthly Salary (₱)</label>
            <input type="number" name="monthly_salary" class="form-control" placeholder="50000.00" step="0.01" min="0">
          </div>

          <hr>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">
              <i class="fas fa-paper-plane me-2"></i>Send Invite
            </button>
            <a href="/staff" class="btn btn-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- 👇 SCRIPT TO TOGGLE RATE/SALARY FIELDS -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const payTypeSelect = document.getElementById('payTypeSelect');
    const hourlyField = document.getElementById('hourlyRateField');
    const salaryField = document.getElementById('monthlySalaryField');

    payTypeSelect.addEventListener('change', function() {
      if (this.value === 'salary') {
        hourlyField.style.display = 'none';
        salaryField.style.display = 'block';
      } else {
        hourlyField.style.display = 'block';
        salaryField.style.display = 'none';
      }
    });
  });
</script>

<%- include('../partials/footer') %>