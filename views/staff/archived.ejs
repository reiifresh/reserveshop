<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
  <h2><i class="fas fa-archive text-warning me-2"></i>Archived Staff</h2>
  <a href="/staff" class="btn btn-secondary">
    <i class="fas fa-arrow-left me-2"></i>Back to Active Staff
  </a>
</div>

<% if (req.session && req.session.message) { %>
  <div class="alert alert-info"><%= req.session.message %></div>
  <% req.session.message = null; %>
<% } %>

<% if (staff.length === 0) { %>
  <div class="alert alert-info">
    <i class="fas fa-info-circle me-2"></i>No archived staff members.
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm bg-white rounded">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Deleted At</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% staff.forEach(user => { %>
          <tr>
            <td>#<%= user.id %></td>
            <td><%= user.full_name || 'N/A' %></td>
            <td><%= user.email %></td>
            <td>
              <span class="badge bg-secondary"><%= user.role %></span>
            </td>
            <td><%= new Date(user.deleted_at).toLocaleString() %></td>
            <td class="text-center">
              <form method="POST" action="/staff/restore/<%= user.id %>" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-success" 
                        onclick="return confirm('Restore this staff member?')">
                  <i class="fas fa-undo me-1"></i>Restore
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>