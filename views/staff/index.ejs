<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
  <h2><i class="fas fa-users-cog text-primary me-2"></i>Staff Management</h2>
  <div>
    <a href="/staff/archived" class="btn btn-outline-warning me-2">
      <i class="fas fa-archive me-2"></i>Archived
    </a>
    <a href="/staff/add" class="btn btn-success">
      <i class="fas fa-user-plus me-2"></i>Add Staff
    </a>
  </div>
</div>

<% if (staff.length === 0) { %>
  <div class="alert alert-info">
    <i class="fas fa-info-circle me-2"></i>No staff members yet. Invite someone!
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm bg-white rounded">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
          <!-- 👇 NEW COLUMN: PAY DETAILS -->
          <th style="min-width: 280px;">Pay Details</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% staff.forEach(user => { %>
          <tr>
            <td>#<%= user.id %></td>
            <td><%= user.full_name || 'N/A' %></td>
            <td><%= user.email %></td>
            <td>
              <span class="badge bg-secondary"><%= user.role %></span>
            </td>
            <td><%= new Date(user.created_at).toLocaleDateString() %></td>

            <!-- ─── PAY DETAILS FORM ─── -->
            <td>
              <form method="POST" action="/staff/update-pay/<%= user.id %>" class="row g-1 align-items-center">
                <!-- Pay Type Dropdown -->
                <div class="col-6">
                  <select name="pay_type" class="form-select form-select-sm pay-type-select" data-id="<%= user.id %>">
                    <option value="hourly" <%= user.pay_type === 'hourly' ? 'selected' : '' %>>Hourly</option>
                    <option value="salary" <%= user.pay_type === 'salary' ? 'selected' : '' %>>Salary</option>
                  </select>
                </div>

                <!-- Hourly Rate (visible if pay_type = hourly) -->
                <div class="col-6 hourly-rate-input" id="hourly-rate-<%= user.id %>" style="<%= user.pay_type === 'salary' ? 'display:none' : '' %>">
                  <input type="number" name="hourly_rate" value="<%= user.hourly_rate || 0 %>"
                         class="form-control form-control-sm" step="0.01" min="0" placeholder="Rate">
                </div>

                <!-- Monthly Salary (visible if pay_type = salary) -->
                <div class="col-6 monthly-salary-input" id="monthly-salary-<%= user.id %>" style="<%= user.pay_type === 'hourly' ? 'display:none' : '' %>">
                  <input type="number" name="monthly_salary" value="<%= user.monthly_salary || 0 %>"
                         class="form-control form-control-sm" step="0.01" min="0" placeholder="Salary">
                </div>

                <!-- Save Button -->
                <div class="col-12">
                  <button type="submit" class="btn btn-sm btn-primary w-100">
                    <i class="fas fa-save me-1"></i>Update Pay
                  </button>
                </div>
              </form>
            </td>

            <!-- ─── ACTIONS ─── -->
            <td class="text-center">
              <a href="/staff/delete/<%= user.id %>" class="btn btn-sm btn-outline-danger"
                 onclick="return confirm('Are you sure you want to remove this staff member?')">
                <i class="fas fa-user-minus me-1"></i>Remove
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<div class="mt-3">
  <a href="/dashboard" class="btn btn-secondary">
    <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
  </a>
</div>

<!-- 👇 SCRIPT TO TOGGLE RATE/SALARY FIELDS -->
<script>
  document.querySelectorAll('.pay-type-select').forEach(select => {
    select.addEventListener('change', function() {
      const userId = this.dataset.id;
      const hourlyDiv = document.getElementById('hourly-rate-' + userId);
      const salaryDiv = document.getElementById('monthly-salary-' + userId);

      if (this.value === 'salary') {
        hourlyDiv.style.display = 'none';
        salaryDiv.style.display = 'block';
      } else {
        hourlyDiv.style.display = 'block';
        salaryDiv.style.display = 'none';
      }
    });
  });
</script>

<%- include('../partials/footer') %>