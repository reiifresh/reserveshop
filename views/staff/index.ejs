<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
  <h2><i class="fas fa-users-cog text-primary me-2"></i>Staff Management</h2>
  <div>
    <a href="/staff/archived" class="btn btn-outline-warning me-2">
      <i class="fas fa-archive me-2"></i>Archived
    </a>
    <a href="/staff/add" class="btn btn-success">
      <i class="fas fa-user-plus me-2"></i>Add Staff
    </a>
  </div>
</div>

<% if (staff.length === 0) { %>
  <div class="alert alert-info">
    <i class="fas fa-info-circle me-2"></i>No staff members yet. Invite someone!
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm bg-white rounded">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
          <th>Hourly Rate (₱)</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% staff.forEach(user => { %>
          <tr>
            <td>#<%= user.id %></td>
            <td><%= user.full_name || 'N/A' %></td>
            <td><%= user.email %></td>
            <td>
              <span class="badge bg-secondary"><%= user.role %></span>
            </td>
            <td><%= new Date(user.created_at).toLocaleDateString() %></td>

            <!-- Hourly Rate (with inline edit) -->
            <td>
              <form method="POST" action="/staff/update-rate/<%= user.id %>" class="d-flex gap-1">
                <input type="number" name="hourly_rate" value="<%= user.hourly_rate || 0 %>"
                       class="form-control form-control-sm" style="width: 100px;" step="0.01" min="0">
                <button type="submit" class="btn btn-sm btn-primary">
                  <i class="fas fa-save"></i>
                </button>
              </form>
            </td>

            <!-- Actions -->
            <td class="text-center">
              <a href="/staff/delete/<%= user.id %>" class="btn btn-sm btn-outline-danger"
                 onclick="return confirm('Are you sure you want to remove this staff member?')">
                <i class="fas fa-user-minus me-1"></i>Remove
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<div class="mt-3">
  <a href="/dashboard" class="btn btn-secondary">
    <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
  </a>
</div>

<%- include('../partials/footer') %>