<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
  <h2><i class="fas fa-history text-primary me-2"></i>Activity Log</h2>
  <span class="text-muted">Last 100 actions</span>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover shadow-sm bg-white rounded">
    <thead class="table-dark">
      <tr>
        <th>Time</th>
        <th>User</th>
        <th>Action</th>
        <th>Details</th>
      </tr>
    </thead>
    <tbody>
      <% logs.forEach(log => { %>
        <tr>
          <td><%= new Date(log.created_at).toLocaleString() %></td>
          <td><%= log.user_email || 'Unknown' %></td>
          <td>
            <span class="badge 
              <%= log.action.includes('LOGIN') ? 'bg-success' : 
                  log.action.includes('LOGOUT') ? 'bg-secondary' :
                  log.action.includes('DELETED') ? 'bg-danger' :
                  log.action.includes('CREATED') ? 'bg-primary' :
                  log.action.includes('UPDATED') ? 'bg-warning' : 'bg-info' %>">
              <%= log.action %>
            </span>
          </td>
          <td><%= log.details || '-' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>