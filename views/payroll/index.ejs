<%- include('../partials/header') %>

<div class="row mt-4">
  <div class="col-12">
    <h2><i class="fas fa-coins text-success me-2"></i>Payroll</h2>
    <hr>
  </div>
</div>

<% if (message) { %>
  <div class="alert alert-info"><%= message %></div>
<% } %>

<!-- Month Selector -->
<div class="card card-shadow border-0 mb-4">
  <div class="card-body">
    <form method="GET" action="/payroll" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Month</label>
        <select name="month" class="form-select">
          <% for (let m = 1; m <= 12; m++) { %>
            <option value="<%= m %>" <%= m === month ? 'selected' : '' %>>
              <%= new Date(2026, m - 1).toLocaleString('en-US', { month: 'long' }) %>
            </option>
          <% } %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Year</label>
        <select name="year" class="form-select">
          <% for (let y = 2024; y <= 2027; y++) { %>
            <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
          <% } %>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary">
          <i class="fas fa-search me-1"></i>Generate
        </button>
      </div>
      <div class="col-md-3 text-end">
        <a href="/payroll/export?month=<%= month %>&year=<%= year %>" class="btn btn-success">
          <i class="fas fa-file-csv me-1"></i>Export CSV
        </a>
      </div>
    </form>
  </div>
</div>

<!-- Payroll Table -->
<div class="card card-shadow border-0">
  <div class="card-header bg-transparent border-0 pt-3">
    <h5 class="mb-0">
      <i class="fas fa-file-invoice-dollar text-success me-2"></i>
      <%= monthName %> <%= year %> Payroll
    </h5>
  </div>
  <div class="card-body">
    <% if (payroll.length === 0) { %>
      <p class="text-muted">No staff found for this period.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead class="table-dark">
            <tr>
              <th>Staff</th>
              <th>Email</th>
              <th>Rate (₱)</th>
              <th>Total Hours</th>
              <th>Unpaid Hours</th>
              <th>Net Hours</th>
              <th>Gross Pay (₱)</th>
            </tr>
          </thead>
          <tbody>
            <% payroll.forEach(emp => { %>
              <tr>
                <td><%= emp.full_name || 'N/A' %></td>
                <td><%= emp.email %></td>
                <td>₱<%= emp.rate ? emp.rate.toFixed(2) : '0.00' %></td>
                <td><%= emp.totalHours.toFixed(2) %></td>
                <td><%= emp.unpaidHours.toFixed(2) %></td>
                <td><strong><%= emp.netHours.toFixed(2) %></strong></td>
                <td><strong>₱<%= emp.grossPay.toFixed(2) %></strong></td>
              </tr>
            <% }) %>
          </tbody>
          <tfoot class="table-dark">
            <tr>
              <th colspan="3">Totals</th>
              <th><%= totalHours.toFixed(2) %></th>
              <th>-</th>
              <th>-</th>
              <th>₱<%= totalPayroll.toFixed(2) %></th>
            </tr>
          </tfoot>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>